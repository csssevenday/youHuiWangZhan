# CJ Affiliate Configuration
# Get these from your CJ account: https://account.cj.com
CJ_PUBLISHER_ID=your_publisher_id
CJ_WEBSITE_ID=your_website_id

# CJ Tracking Domain (usually www.anrdoezrs.net or www.tkqlhce.com)
CJ_TRACKING_DOMAIN=www.anrdoezrs.net

# Site URL
SITE_URL=http://localhost:3000

# Vercel Deployment:
# Copy these variables to Vercel project settings:
# Settings > Environment Variables
# - CJ_PUBLISHER_ID
# - CJ_WEBSITE_ID
# - CJ_TRACKING_DOMAIN
# - SITE_URL (set to https://your-domain.com)
